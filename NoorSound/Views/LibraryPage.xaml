<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoorSound.Views.LibraryPage"
			 xmlns:viewmodel="clr-namespace:NoorSound.ViewModels"
			 x:DataType="viewmodel:LibraryViewModel"
			 xmlns:model="clr-namespace:NoorSound.Models"
			 xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             Title="LibraryPage">

	
	<Grid
    Margin="20"
    RowDefinitions="Auto,*"
    RowSpacing="10">
		<Grid Grid.Row="0" ColumnDefinitions="*,*">
			<Button
            Grid.Column="1"
            Background="DarkOrange"
            Command="{Binding AddAudioCommand}"
            HorizontalOptions="End"
            Text="Add"
            TextColor="#eff5f3" />
		</Grid>

		<CollectionView Grid.Row="1" ItemsSource="{Binding Audios}">
			<CollectionView.ItemsLayout>
				<LinearItemsLayout ItemSpacing="4" Orientation="Vertical" />
			</CollectionView.ItemsLayout>

			<CollectionView.ItemTemplate>
				<DataTemplate x:DataType="model:Audio">
					<Border
                         Padding="15"
                         Stroke="Dimgray"
                         Background="#601d2021"
                         StrokeThickness="2">
						<Border.StrokeShape>
							<RoundRectangle CornerRadius="10,10,10,10" />
						</Border.StrokeShape>
						<Grid RowDefinitions="Auto,*" RowSpacing="4">
							<Image
                                 Grid.Row="0"
                                 Aspect="AspectFill"
                                 HeightRequest="200"
                                 HorizontalOptions="Center"
                                 Source="{Binding ImageUrl }"
                                 VerticalOptions="Center" />

							<Grid Grid.Row="1" RowDefinitions="Auto,Auto,Auto">
								<Label
                                Grid.Row="0"
                                FontAttributes="Bold"
                                FontSize="Medium"
                                Text="{Binding AudioName}" />

								<Label
                                Grid.Row="1"
                                Margin="0,2"
                                FontSize="Small"
                                Text="{Binding Admin.Name}" />

								<Grid
                                Grid.Row="2"
                                Margin="0,5"
                                ColumnDefinitions="Auto,Auto,*">
									<Button
                                    Grid.Column="0"
                                    BackgroundColor="OrangeRed"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:LibraryViewModel}}, Path=DeleteAudioCommand}"
                                    CommandParameter="{Binding .}"
                                    Text="Delete"
                                    TextColor="#eff5f3" />
								</Grid>
							</Grid>
						</Grid>
					</Border>
				</DataTemplate>
			</CollectionView.ItemTemplate>


		</CollectionView>

	</Grid>



</ContentPage>