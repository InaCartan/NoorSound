<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoorSound.Views.AddAudioPage"
			 xmlns:viewmodel="clr-namespace:NoorSound.ViewModels"
             x:DataType="viewmodel:AddAudioViewModel"
             xmlns:model="clr-namespace:NoorSound.Models"
             Title="Add Audio">
    
	<ScrollView>
		<VerticalStackLayout Padding="24" Spacing="16">

			<Label Text="Audio Name" FontAttributes="Bold" />
			<Entry Placeholder="Enter audio name"
                   Text="{Binding NewAudioName}" />

			<Label Text="Admin Name" FontAttributes="Bold" />
			<Entry Placeholder="Enter admin name"
                   Text="{Binding NewAdmin.Name}" />

			<!-- Image Picker -->
			<Label Text="Cover Image" FontAttributes="Bold" />
			<Button Text="Pick Image"
                    Command="{Binding PickImageCommand}" />
			<Image Source="{Binding NewImageUrl}"
                   HeightRequest="120"
                   Aspect="AspectFit"
                   IsVisible="{Binding NewImageUrl, Converter={StaticResource StringToBoolConverter}}" />

			<!-- Audio Picker -->
			<Label Text="Audio File" FontAttributes="Bold" />
			<Button Text="Pick Audio File"
                    Command="{Binding PickAudioCommand}" />
			<Label Text="{Binding NewAudioUrl}"
                   FontSize="12"
                   TextColor="Gray"
                   LineBreakMode="TailTruncation"
                   IsVisible="{Binding NewAudioUrl, Converter={StaticResource StringToBoolConverter}}" />

			<!-- Submit -->
			<Button Text="Add Audio"
                    Command="{Binding AddAudioCommand}"
                    Margin="0,16,0,0" />

			<ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>