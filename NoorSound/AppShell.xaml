<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="NoorSound.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:NoorSound"
    xmlns:views="clr-namespace:NoorSound.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="NoorSound">

    <!-- Login & SignUp -->
    <ShellContent
        Route="LoginPage"
        ContentTemplate="{DataTemplate views:LoginPage}" />

    <ShellContent
        Route="SignUpPage"
        ContentTemplate="{DataTemplate views:SignUpPage}" />



    <TabBar>

        <!-- Home -->
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:HomePage}" 
            Route="HomePage"/>

        <!-- Library -->
        <ShellContent
            Title="Library"
            ContentTemplate="{DataTemplate views:LibraryPage}"
            Route="LibraryPage"/>

    </TabBar>

</Shell>
